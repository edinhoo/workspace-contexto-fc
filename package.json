{
  "name": "contexto-fc",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:data-api": "pnpm --filter @services/data-api start",
    "directus:down": "docker compose -f infra/docker/docker-compose.yml stop directus",
    "directus:logs": "docker compose -f infra/docker/docker-compose.yml logs -f directus",
    "directus:up": "docker compose -f infra/docker/docker-compose.yml up -d directus",
    "lint": "turbo run lint",
    "scrape:sofascore": "pnpm --filter @services/sofascore scrape",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:dry-run:phase2": "node scripts/db/dry-run-phase2.mjs",
    "db:migrate": "node scripts/db/migrate.mjs",
    "db:bootstrap:phase1": "node scripts/db/bootstrap-phase1.mjs",
    "db:cancel-scheduled-scrape:phase5": "node scripts/db/automation/cancel-scheduled-scrape.mjs",
    "db:ingest:phase2": "node scripts/db/ingest-phase2.mjs",
    "db:plan-match:phase5": "node scripts/db/automation/plan-match.mjs",
    "db:rerun-scheduled-scrape:phase5": "node scripts/db/automation/rerun-scheduled-scrape.mjs",
    "db:run-scheduler:phase5": "node scripts/db/automation/run-scheduler.mjs",
    "db:validate:phase1": "node scripts/db/validate-phase1.mjs",
    "db:validate:phase2": "node scripts/db/validate-phase2.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.1",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "ulid": "^2.4.0"
  }
}
