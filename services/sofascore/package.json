{
  "name": "@services/sofascore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@repo/utils": "workspace:*"
  },
  "scripts": {
    "build": "pnpm --filter @repo/utils build && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "scrape": "pnpm run build > /dev/null 2>&1 && node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "node --test",
    "typecheck": "pnpm --filter @repo/utils build > /dev/null 2>&1 && tsc -p tsconfig.build.json --noEmit"
  }
}
