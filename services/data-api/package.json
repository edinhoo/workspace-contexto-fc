{
  "name": "@services/data-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.3.3",
    "kysely": "^0.28.2",
    "pg": "^8.16.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "pnpm run build > /dev/null 2>&1 && node dist/server.js",
    "lint": "eslint src --ext .ts",
    "test": "rm -rf dist-test && tsc -p tsconfig.test.json && node --test 'dist-test/src/**/*.test.js'",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  }
}
