{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Database: Start Postgres",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm docker:up"
    },
    {
      "name": "Database: Stop Postgres",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm docker:down"
    },
    {
      "name": "Database: Migrate",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm db:migrate"
    },
    {
      "name": "Database: Ingest Phase 2",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm db:ingest:phase2"
    },
    {
      "name": "Database: Validate Phase 2",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm db:validate:phase2"
    },
    {
      "name": "Database: Dry Run Phase 2",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm db:dry-run:phase2"
    },
    {
      "name": "Web: Scrape Reference Match",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter @services/sofascore scrape 15237889"
    },
    {
      "name": "Web: Start Data API",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter @services/data-api start"
    },
    {
      "name": "Web: Start Web App",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter @apps/web dev"
    },
    {
      "name": "Web: Start Full Local Stack",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm web:up"
    },
    {
      "name": "Web: Stop Full Local Stack",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm web:down"
    }
  ]
}
